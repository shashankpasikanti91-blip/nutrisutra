# NutriSutra Backend Environment
# Copy to .env and fill in values.

# OpenRouter (optional — leave blank to use text-only mode)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Feature flags
ENABLE_OPENROUTER_IMAGE_ANALYSIS=false
ENABLE_IMAGE_RESULT_PERSISTENCE=true

# Upload limits
MAX_IMAGE_UPLOAD_MB=5

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
